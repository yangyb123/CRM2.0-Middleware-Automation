                        .header h1 { font-size: 28px; margin-bottom: 8px; font-weight: bold; }
                        .header p { font-size: 14px; opacity: 0.95; }
                        .content { padding: 20px; }
                        .section { margin: 25px 0; }
                        .section-title { font-size: 18px; font-weight: bold; color: #fff; background-color: #0066cc; padding: 12px 15px; margin: -20px -20px 15px -20px; border-left: 4px solid #0052a3; }
                        .info-box { background-color: #f0f8ff; padding: 15px; margin: 10px 0; border-left: 4px solid #0066cc; border-radius: 4px; }
                        .info-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e0e0e0; }
                        .info-row:last-child { border-bottom: none; }
                        .info-label { font-weight: bold; color: #0066cc; min-width: 140px; }
                        .info-value { color: #333; text-align: right; flex: 1; }
