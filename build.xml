                        .stat-card { background: linear-gradient(135deg, #f0f8ff 0%, #e6f2ff 100%); padding: 15px; border-radius: 6px; border-left: 4px solid #0066cc; text-align: center; }
                        .stat-label { font-size: 12px; color: #666; margin-bottom: 8px; }
                        .stat-value { font-size: 28px; font-weight: bold; color: #0066cc; }
                        .stat-unit { font-size: 12px; color: #999; }
                        .success { border-left-color: #28a745; }
                        .success .stat-value { color: #28a745; }
                        .warning { border-left-color: #ffc107; }
                        .warning .stat-value { color: #ffc107; }
                        .error { border-left-color: #dc3545; }
                        .error .stat-value { color: #dc3545; }
                        .link-box { background-color: #f9f9f9; padding: 15px; border-radius: 4px; margin: 10px 0; }
                        .link-item { margin: 12px 0; padding: 10px; background-color: #fff; border-radius: 4px; border-left: 3px solid #0066cc; }
