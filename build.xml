                        .link-item a:hover { text-decoration: underline; }
                        .link-desc { color: #666; font-size: 12px; margin-top: 5px; }
                        .attachment-list { background-color: #f9f9f9; padding: 15px; border-radius: 4px; }
                        .attachment-item { padding: 8px 0; border-bottom: 1px solid #e0e0e0; font-size: 13px; }
                        .attachment-item:last-child { border-bottom: none; }
                        .attachment-name { font-weight: bold; color: #0066cc; }
                        .attachment-desc { color: #666; font-size: 12px; margin-left: 20px; }
                        .footer { color: #999; font-size: 12px; padding: 20px; background-color: #f5f5f5; text-align: center; border-top: 1px solid #ddd; }
                        .footer p { margin: 5px 0; }
                        .tips { background-color: #fff3cd; padding: 12px; border-radius: 4px; margin: 10px 0; border-left: 4px solid #ffc107; }
                        .tips strong { color: #856404; }
                        ul { margin-left: 20px; }
                        li { margin: 8px 0; }
                        table { width: 100%; border-collapse: collapse; margin: 10px 0; }
                        th { background-color: #f0f8ff; padding: 10px; text-align: left; border-bottom: 2px solid #0066cc; font-weight: bold; color: #0066cc; }
                        td { padding: 10px; border-bottom: 1px solid #e0e0e0; }
                    </style>
                </head>
                <body>
                    <div class="container">
                        <div class="header">
                            <h1>${project.name} 自动化测试报告</h1>
                            <p>${project.name} 自动化测试结果通知</p>
                        </div>
                        
                        <div class="content">
                            <!-- 一、测试概况 -->
                            <div class="section">
                                <div class="section-title">一、测试概况</div>
                                <div class="info-box">
                                    <div class="info-row">
                                        <span class="info-label">项目名称:</span>
                                        <span class="info-value">${project.name}</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">测试类型:</span>
                                        <span class="info-value">${test.type}</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">测试环境:</span>
                                        <span class="info-value">${test.environment}</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">测试时间:</span>
                                        <span class="info-value">${timestamp.date} ${timestamp.time}</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">报告名称:</span>
                                        <span class="info-value">${report.prefix}</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- 二、测试结果 -->
                            <div class="section">
                                <div class="section-title">二、测试结果概览</div>
                                <div class="stats-grid">
                                    <div class="stat-card">
                                        <div class="stat-label">接口总数</div>
                                        <div class="stat-value">${stats.total}</div>
                                        <div class="stat-unit">个</div>
                                    </div>
                                    <div class="stat-card success">
                                        <div class="stat-label">成功数</div>
                                        <div class="stat-value">${stats.success}</div>
                                        <div class="stat-unit">个</div>
                                    </div>
                                    <div class="stat-card error">
                                        <div class="stat-label">失败数</div>
                                        <div class="stat-value">${stats.failure}</div>
                                        <div class="stat-unit">个</div>
                                    </div>
                                </div>
                                <div class="info-box">
                                    <div class="info-row">
                                        <span class="info-label">接口成功率:</span>
                                        <span class="info-value" style="color: #28a745; font-weight: bold;">${stats.success_rate}%</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- 五、邮件附件说明 -->
                            <div class="section">
                                <div class="section-title">三、邮件附件说明</div>
                                <div class="attachment-list">
                                    <div class="attachment-item">
                                        <span class="attachment-name">📊 ${report.prefix}_Summary.html</span>
                                        <div class="attachment-desc">汇总报告（HTML 格式）- 包含关键指标和统计数据</div>
                                    </div>
                                    <div class="attachment-item">
                                        <span class="attachment-name">📄 ${report.prefix}_Detail.html</span>
                                        <div class="attachment-desc">详细报告（HTML 格式）- 包含所有测试用例详情</div>
                                    </div>
