            <stringProp name="script">int count = vars.get(&quot;loop_count_Loop10&quot;) == null ? 0 : Integer.parseInt(vars.get(&quot;loop_count_Loop10&quot;));

if (count == 0) {
    vars.put(&quot;instanceid_val&quot;, vars.get(&quot;mt5instanceid&quot;));
} else {
    vars.put(&quot;instanceid_val&quot;, vars.get(&quot;mt4instanceid&quot;));
}

