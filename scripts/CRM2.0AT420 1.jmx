              <hashTree/>
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言" enabled="false">
                <stringProp name="scriptLanguage">beanshell</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">String b1 = &quot;0&quot;;
if (vars.get(&quot;get_before_totalBalance&quot;) != null) {
    b1 = vars.get(&quot;get_before_totalBalance&quot;);
}

String amt = &quot;0&quot;;
if (vars.get(&quot;amount&quot;) != null) {
    amt = vars.get(&quot;amount&quot;);
}

String b2 = &quot;0&quot;;
if (vars.get(&quot;get_after_totalBalancer&quot;) != null) {
    b2 = vars.get(&quot;get_after_totalBalance&quot;);
}

// 转为金额数字
double before = Double.parseDouble(b1);
double amount = Double.parseDouble(amt);
double after = Double.parseDouble(b2);

// 计算
double real = after - before;
double expect = amount;

log.info(&quot;before=&quot;+before+&quot; , after=&quot;+after);
log.info(&quot;实际差额=&quot;+real+&quot; , 预期差额=&quot;+expect);

// 精度匹配
boolean pass = Math.abs(real - expect) &lt; 0.001;

if (!pass) {
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;余额不匹配：实际变化=&quot;+real+&quot;，预期=&quot;+expect);
} else {
    AssertionResult.setFailure(false);
}</stringProp>
              </JSR223Assertion>
              <hashTree/>
              <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言" enabled="true">
                <stringProp name="scriptLanguage">beanshell</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// 获取变量（小数）
double before = Double.parseDouble(vars.get(&quot;get_before_totalBalance&quot;));
double after = Double.parseDouble(vars.get(&quot;get_after_totalBalance&quot;));
double amount = Double.parseDouble(vars.get(&quot;amount&quot;));

// 计算
double actual = after - before;
double expect = amount;

// 允许微小精度误差
if (Math.abs(actual - expect) &lt; 0.001) {
    SampleResult.setResponseOK();
    SampleResult.setResponseMessage(&quot;入金余额校验成功&quot;);
} else {
    throw new AssertionError(
        &quot;入金余额校验失败！\n&quot; +
        &quot;实际增加：&quot; + actual + &quot;\n&quot; +
        &quot;预期增加：&quot; + expect
    );
}</stringProp>
              </JSR223Assertion>
