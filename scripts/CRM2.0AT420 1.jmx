            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="对比杠杆" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">String lev = vars.get(&quot;lev&quot;);
String leverage = vars.get(&quot;client_leverage&quot;);
String middle_leverage = vars.get(&quot;middle_leverage&quot;);
String admin_leverage = vars.get(&quot;admin_leverage&quot;);

// JMeter 固定写法
boolean failure = false;
String failureMessage = &quot;&quot;;

// 判空
if (lev == null || leverage == null || middle_leverage == null || admin_leverage == null) {
    failure = true;
    failureMessage = &quot;❌ 有变量为空：lev=&quot; + lev + &quot; client_leverage=&quot; + leverage + &quot; middle_leverage=&quot; + middle_leverage + &quot;admin_leverage=&quot; + admin_leverage;
} 
// 四个值必须全部相等
else if (lev.equals(leverage) &amp;&amp; lev.equals(middle_leverage)) {
    failureMessage = &quot;✅ 断言成功：四个值完全一致！lev=&quot; + lev + &quot; client_leverage=&quot; + leverage + &quot; middle_leverage=&quot; + middle_leverage + &quot;admin_leverage=&quot; + admin_leverage;
} 
// 不相等
else {
    failure = true;
    failureMessage = &quot;❌ 断言失败：四个值不一致！lev=&quot; + lev + &quot; client_leverage=&quot; + leverage + &quot; middle_leverage=&quot; + middle_leverage + &quot;admin_leverage=&quot; + admin_leverage;
}


vars.put(&quot;assertResult&quot;, failureMessage);  // 把结果存下来
Failure = failure;                        // 告诉JMeter是否失败
FailureMessage = failureMessage;          // 显示信息</stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
        </hashTree>
      </hashTree>
