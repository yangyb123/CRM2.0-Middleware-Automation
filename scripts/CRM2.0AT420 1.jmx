        <hashTree>
          <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSV 数据文件设置" enabled="true">
            <stringProp name="filename">Withdraw Automation data.csv</stringProp>
            <stringProp name="fileEncoding">UTF-8</stringProp>
            <stringProp name="variableNames">withdraw_type,currency,accountId,sourceType,amount,channelId,paymentMethod,currencyId,initial_status,risk_status,deduction_status,cardInfo,cryptoInfo,eWalletInfo,wireTransferInfo,bankInfo</stringProp>
            <boolProp name="ignoreFirstLine">true</boolProp>
            <stringProp name="delimiter">#</stringProp>
