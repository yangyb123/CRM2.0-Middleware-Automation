            <BeanShellAssertion guiclass="BeanShellAssertionGui" testclass="BeanShellAssertion" testname="BeanShell断言" enabled="true">
              <stringProp name="BeanShellAssertion.query">// 获取三个接口的匹配数量（总订单数）
String clientCountStr = vars.get(&quot;client_history_orderId41_matchNr&quot;);
String adminCountStr = vars.get(&quot;admin_history_orderId41_matchNr&quot;);
String middleCountStr = vars.get(&quot;middle_history_orderId41_matchNr&quot;);

int clientCount = 0;
int adminCount = 0;
int middleCount = 0;

try {
    clientCount = Integer.parseInt(clientCountStr);
} catch (Exception e) {}
try {
    adminCount = Integer.parseInt(adminCountStr);
} catch (Exception e) {}
try {
    middleCount = Integer.parseInt(middleCountStr);
} catch (Exception e) {}

log.info(&quot;===== 三方订单数量对比 =====&quot;);
log.info(&quot;客户端订单数: &quot; + clientCount);
log.info(&quot;后台订单数: &quot; + adminCount);
log.info(&quot;中间件订单数: &quot; + middleCount);

Set clientOrderIds = new HashSet();
Set adminOrderIds = new HashSet();
Set middleOrderIds = new HashSet();

for (int i = 1; i &lt;= clientCount; i++) {
    String id = vars.get(&quot;client_history_orderId41_&quot; + i);
    if (id != null &amp;&amp; !id.isEmpty()) clientOrderIds.add(id);
}
for (int i = 1; i &lt;= adminCount; i++) {
    String id = vars.get(&quot;admin_history_orderId41_&quot; + i);
    if (id != null &amp;&amp; !id.isEmpty()) adminOrderIds.add(id);
}
for (int i = 1; i &lt;= middleCount; i++) {
    String id = vars.get(&quot;middle_history_orderId41_&quot; + i);
    if (id != null &amp;&amp; !id.isEmpty()) middleOrderIds.add(id);
}

if (!clientOrderIds.equals(adminOrderIds) || !adminOrderIds.equals(middleOrderIds)) {
    Failure = true;
    FailureMessage = &quot;订单号集合不一致！\n&quot;
                   + &quot;客户端订单：&quot; + clientOrderIds + &quot;\n&quot;
                   + &quot;后台订单：&quot; + adminOrderIds + &quot;\n&quot;
                   + &quot;中间件订单：&quot; + middleOrderIds;
    return;
}

log.info(&quot;✅ 三方订单号集合完全一致：&quot; + clientOrderIds);

for (Iterator it = clientOrderIds.iterator(); it.hasNext();) {
    String orderId = (String) it.next();
    log.info(&quot;正在校验订单：&quot; + orderId);

    // ===================== 客户端字段 =====================
    String clientType = null;
    String clientSymbol = null;
    String clientLots = null;
    for (int i = 1; i &lt;= clientCount; i++) {
        if (orderId.equals(vars.get(&quot;client_history_orderId41_&quot; + i))) {
            String cmdStr = vars.get(&quot;client_history_cmd41_&quot; + i);
            int cmd = 0;
            try {
                cmd = Integer.parseInt(cmdStr);
            } catch (Exception e) {}
            clientType = String.valueOf(cmd - 1);
            clientSymbol = vars.get(&quot;client_history_Symbol41_&quot; + i);
            clientLots = vars.get(&quot;client_history_Volume41_&quot; + i);
            break;
        }
    }

    // ===================== 后台字段 =====================
    String adminType = null;
    String adminSymbol = null;
    String adminLots = null;
    for (int i = 1; i &lt;= adminCount; i++) {
        if (orderId.equals(vars.get(&quot;admin_history_orderId41_&quot; + i))) {
            adminType = vars.get(&quot;admin_history_cmd41_&quot; + i);
            adminSymbol = vars.get(&quot;admin_history_Symbol41_&quot; + i);
            adminLots = vars.get(&quot;admin_history_Volume41_&quot; + i);
            break;
        }
    }

    // ===================== 中间件字段 =====================
    String middleType = null;
    String middleSymbol = null;
    String middleLots = null;
    for (int i = 1; i &lt;= middleCount; i++) {
        if (orderId.equals(vars.get(&quot;middle_history_orderId41_&quot; + i))) {
            // 1. side 转换 buy=0 sell=1
            String sideVal = vars.get(&quot;middle_history_cmd41_&quot; + i);
            if(sideVal != null){
                if(&quot;buy&quot;.equalsIgnoreCase(sideVal)){
                    middleType = &quot;0&quot;;
                }else if(&quot;sell&quot;.equalsIgnoreCase(sideVal)){
                    middleType = &quot;1&quot;;
                }else{
                    middleType = sideVal;
                }
            }

            middleSymbol = vars.get(&quot;middle_history_Symbol41_&quot; + i);
   
            middleLots = vars.get(&quot;middle_history_Volume41_&quot; + i);
            break;
        }
    }

    // ========== 交易方向校验 ==========
    if(clientType == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【客户端】交易方向字段为空&quot;;
        return;
    }
    if(adminType == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【后台】交易方向字段为空&quot;;
        return;
    }
    if(middleType == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【中间件】交易方向(side)为空&quot;;
        return;
    }
    if (!clientType.equals(adminType) || !adminType.equals(middleType)) {
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】交易方向不一致：\n&quot;
                       + &quot;客户端方向：&quot; + clientType + &quot;\n&quot;
                       + &quot;后台方向：&quot; + adminType + &quot;\n&quot;
                       + &quot;中间件方向：&quot; + middleType;
        return;
    }

    // ========== 品种校验 ==========
    if(clientSymbol == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【客户端】品种字段为空&quot;;
        return;
    }
    if(adminSymbol == null){
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【后台】品种字段为空&quot;;
        return;
    }
    if(middleSymbol == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【中间件】品种字段为空&quot;;
        return;
    }
    if (!clientSymbol.equals(adminSymbol) || !adminSymbol.equals(middleSymbol)) {
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】品种不一致：\n&quot;
                       + &quot;客户端品种：&quot; + clientSymbol + &quot;\n&quot;
                       + &quot;后台品种：&quot; + adminSymbol + &quot;\n&quot;
                       + &quot;中间件品种：&quot; + middleSymbol;
        return;
    }

    // ========== 手数校验 ==========
    if(clientLots == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【客户端】手数字段为空&quot;;
        return;
    }
    if(adminLots == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【后台】手数字段为空&quot;;
        return;
    }
    if(middleLots == null){
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】校验失败：【中间件】手数字段为空&quot;;
        return;
    }
    if (!clientLots.equals(adminLots) || !adminLots.equals(middleLots)) {
        Failure = true;
        FailureMessage = &quot;订单【&quot;+orderId+&quot;】手数不一致：\n&quot;
                       + &quot;客户端手数：&quot; + clientLots + &quot;\n&quot;
                       + &quot;后台手数：&quot; + adminLots + &quot;\n&quot;
                       + &quot;中间件手数：&quot; + middleLots;
        return;
    }

    log.info(&quot;✅ 订单 &quot; + orderId + &quot; 校验通过&quot;);
}

log.info(&quot;==============================================&quot;);
log.info(&quot;✅ 所有订单校验完成：三方完全一致&quot;);</stringProp>
              <stringProp name="BeanShellAssertion.filename"></stringProp>
