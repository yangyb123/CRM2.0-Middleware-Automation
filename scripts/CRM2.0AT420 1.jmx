              <BeanShellAssertion guiclass="BeanShellAssertionGui" testclass="BeanShellAssertion" testname="BeanShell断言" enabled="true">
                <stringProp name="BeanShellAssertion.query">String aStr = vars.get(&quot;total_num_new&quot;);
String bStr = vars.get(&quot;total_num&quot;);

if (aStr == null || aStr.isEmpty() || bStr == null || bStr.isEmpty()) {
    Failure = true;
    FailureMessage = &quot;订单数量为空！varA=&quot; + aStr + &quot;, varB=&quot; + bStr;
    return;
}

try {
    double a = Double.parseDouble(aStr);
    double b = Double.parseDouble(bStr);
    
    if (a &gt; b) {
        Failure = false;
    } else {
        Failure = true;
        FailureMessage = &quot;断言失败：新记录未产生，转账后订单数量(&quot; + a + &quot;) 不大于转账前订单数量 (&quot; + b + &quot;)&quot;;
    }
} catch (Exception e) {
    Failure = true;
    FailureMessage = &quot;数值转换失败：&quot; + e.getMessage();
}</stringProp>
                <stringProp name="BeanShellAssertion.filename"></stringProp>
                <stringProp name="BeanShellAssertion.parameters"></stringProp>
                <boolProp name="BeanShellAssertion.resetInterpreter">false</boolProp>
              </BeanShellAssertion>
              <hashTree/>
            </hashTree>
