                <hashTree>
                  <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言" enabled="true">
                    <stringProp name="scriptLanguage">beanshell</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">String b1 = &quot;0&quot;;
if (vars.get(&quot;balance_before_1&quot;) != null) {
    b1 = vars.get(&quot;balance_before_1&quot;);
}

String amt = &quot;0&quot;;
if (vars.get(&quot;amount&quot;) != null) {
    amt = vars.get(&quot;amount&quot;);
}

String ref = &quot;0&quot;;
if (vars.get(&quot;refund_amount&quot;) != null) {
    ref = vars.get(&quot;refund_amount&quot;);
}

String b2 = &quot;0&quot;;
if (vars.get(&quot;balance_after_1&quot;) != null) {
    b2 = vars.get(&quot;balance_after_1&quot;);
}

// 转为金额数字
double before = Double.parseDouble(b1);
double amount = Double.parseDouble(amt);
double refund = Double.parseDouble(ref);
double after = Double.parseDouble(b2);

// 计算
double real = after - before;
double expect = amount - refund;

log.info(&quot;before_1=&quot;+before+&quot; , after_1=&quot;+after);
log.info(&quot;实际差额=&quot;+real+&quot; , 预期差额=&quot;+expect);

// 精度匹配
boolean pass = Math.abs(real - expect) &lt; 0.001;

if (!pass) {
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;余额不匹配：实际变化=&quot;+real+&quot;，预期=&quot;+expect);
} else {
    AssertionResult.setFailure(false);
}</stringProp>
                  </JSR223Assertion>
                  <hashTree/>
                  <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言" enabled="false">
                    <stringProp name="scriptLanguage">beanshell</stringProp>
                    <stringProp name="parameters"></stringProp>
                    <stringProp name="filename"></stringProp>
                    <stringProp name="cacheKey">true</stringProp>
                    <stringProp name="script">//安全获取变量，处理null/空值
String bbStr = vars.get(&quot;balance_before&quot;);
String baStr = vars.get(&quot;balance_after&quot;);
String amStr = vars.get(&quot;amount&quot;);
String rfStr = vars.get(&quot;refund_amount&quot;);

//空值兜底为0
double balance_before = (bbStr==null||bbStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(bbStr.trim());
double balance_after  = (baStr==null||baStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(baStr.trim());
double amount         = (amStr==null||amStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(amStr.trim());
double refund_amount  = (rfStr==null||rfStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(rfStr.trim());

//计算
double actual = balance_after - balance_before;
double expect = amount - refund_amount;

//精度容错
if(Math.abs(actual - expect) &lt; 0.001){
    SampleResult.setResponseMessage(&quot;✅入金+退款余额校验通过&quot;);
}else{
    String msg = &quot;❌余额校验失败\r\n&quot;
    + &quot;入金前余额：&quot; + balance_before + &quot;\r\n&quot;
    + &quot;入金后余额：&quot; + balance_after + &quot;\r\n&quot;
    + &quot;实际余额变动：&quot; + actual + &quot;\r\n&quot;
    + &quot;入金金额：&quot; + amount + &quot;\r\n&quot;
    + &quot;退回金额：&quot; + refund_amount + &quot;\r\n&quot;
    + &quot;预期净变动：&quot; + expect;
    throw new AssertionError(msg);
}</stringProp>
                  </JSR223Assertion>
                  <hashTree/>
                </hashTree>
              </hashTree>
