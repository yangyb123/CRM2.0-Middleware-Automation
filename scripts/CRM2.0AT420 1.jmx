                <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 断言" enabled="true">
                  <stringProp name="scriptLanguage">groovy</stringProp>
                  <stringProp name="parameters"></stringProp>
                  <stringProp name="filename"></stringProp>
                  <stringProp name="cacheKey">true</stringProp>
                  <stringProp name="script">def firstStr = vars.get(&quot;totalCredit_1&quot;)
def secondStr = vars.get(&quot;totalCredit_2&quot;)

if (firstStr != null &amp;&amp; secondStr != null) {
    def firstValue = firstStr.toDouble()
    def secondValue = secondStr.toDouble()

    log.info(&quot;第一次值: &quot; + firstValue + &quot;, 第二次值: &quot; + secondValue)

    if (secondValue &lt; firstValue) {
        AssertionResult.setFailure(false)
    } else {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(&quot;断言失败：出金后 (&quot; + secondValue + &quot;) 大于出金前 (&quot; + firstValue + &quot;)&quot;)
    }
} else {
    log.error(&quot;totalCredit_1 或 totalCredit_2 为 null&quot;)
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;无法获取 totalCredit 值进行断言&quot;)
}</stringProp>
                </JSR223Assertion>
