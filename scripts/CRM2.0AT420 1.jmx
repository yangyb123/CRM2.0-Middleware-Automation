            <hashTree>
              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 预处理程序" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// 获取当前循环的索引
int idx = vars.getIteration() - 1

// 获取当前 orderId 对应的 amount，exchangeRate，covertAmount
def amount = vars.get(&quot;amount_&quot; + (idx + 1)) as BigDecimal
def exchangeRate = vars.get(&quot;exchangeRate_&quot; + (idx + 1)) as BigDecimal
def covertAmount = vars.get(&quot;covertAmount_&quot; + (idx + 1)) as BigDecimal


vars.put(&quot;orderId&quot;, vars.get(&quot;orderId_&quot; + (idx + 1)))
vars.put(&quot;amount&quot;, amount.toPlainString())
vars.put(&quot;exchangeRate&quot;, exchangeRate.toPlainString())
vars.put(&quot;covertAmount&quot;, covertAmount.toPlainString())</stringProp>
              </JSR223PreProcessor>
              <hashTree/>
            </hashTree>
