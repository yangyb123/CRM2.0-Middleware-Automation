double balance_before = (bbStr==null||bbStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(bbStr.trim());
double balance_after  = (baStr==null||baStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(baStr.trim());
double amount         = (amStr==null||amStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(amStr.trim());
double refund_amount  = (rfStr==null||rfStr.trim().isEmpty()) ? 0.0 : Double.parseDouble(rfStr.trim());

//计算
double actual = balance_after - balance_before;
double expect = amount - refund_amount;

//精度容错
if(Math.abs(actual - expect) &lt; 0.001){
    SampleResult.setResponseMessage(&quot;✅入金+退款余额校验通过&quot;);
}else{
    String msg = &quot;❌余额校验失败\r\n&quot;
    + &quot;入金前余额：&quot; + balance_before + &quot;\r\n&quot;
    + &quot;入金后余额：&quot; + balance_after + &quot;\r\n&quot;
    + &quot;实际余额变动：&quot; + actual + &quot;\r\n&quot;
    + &quot;入金金额：&quot; + amount + &quot;\r\n&quot;
    + &quot;退回金额：&quot; + refund_amount + &quot;\r\n&quot;
    + &quot;预期净变动：&quot; + expect;
    throw new AssertionError(msg);
}</stringProp>
                  </JSR223Assertion>
                  <hashTree/>
                </hashTree>
              </hashTree>
            </hashTree>
