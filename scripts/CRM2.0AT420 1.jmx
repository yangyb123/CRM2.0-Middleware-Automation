        <hashTree>
          <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell 预处理程序">
            <boolProp name="resetInterpreter">false</boolProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="script">import java.util.Random;

String basePrefix = &quot;auto&quot;;
String suffix = &quot;@test.com&quot;;
String chars = &quot;abcdefghijklmnopqrstuvwxyz0123456789&quot;;
int randomLen = 6; // 随机部分长度，可自行修改

StringBuilder sb = new StringBuilder();
Random rnd = new Random();
for (int i = 0; i &lt; randomLen; i++) {
    sb.append(chars.charAt(rnd.nextInt(chars.length())));
}

// 生成最终邮箱
String email = basePrefix + sb.toString() + suffix;

// 存入JMeter全局变量，所有线程内的接口都能使用
vars.put(&quot;common_email&quot;, email);</stringProp>
            <stringProp name="TestPlan.comments">生成随机邮箱</stringProp>
          </BeanShellPreProcessor>
          <hashTree/>
        </hashTree>
