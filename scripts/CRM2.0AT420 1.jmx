              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="提取用户钱包余额" enabled="true">
                <stringProp name="JSONPostProcessor.referenceNames">get_after_totalBalance</stringProp>
                <stringProp name="JSONPostProcessor.jsonPathExprs">$.totalBalance</stringProp>
                <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
