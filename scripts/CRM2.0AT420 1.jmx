            <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell 预处理程序" enabled="true">
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="script">// ======================================
// 1. 调试打印：验证CSV参数是否读取成功
// ======================================
log.info(&quot;===== 读取CSV参数开始 =====&quot;);
log.info(&quot;withdraw_type: &quot; + vars.get(&quot;withdraw_type&quot;));
log.info(&quot;accountId: &quot; + vars.get(&quot;accountId&quot;));
log.info(&quot;sourceType: &quot; + vars.get(&quot;sourceType&quot;));
log.info(&quot;amount: &quot; + vars.get(&quot;amount&quot;));
log.info(&quot;channelId: &quot; + vars.get(&quot;channelId&quot;));
log.info(&quot;paymentMethod: &quot; + vars.get(&quot;paymentMethod&quot;));
log.info(&quot;currencyId: &quot; + vars.get(&quot;currencyId&quot;));
log.info(&quot;cardInfo: &quot; + vars.get(&quot;cardInfo&quot;));
log.info(&quot;cryptoInfo: &quot; + vars.get(&quot;cryptoInfo&quot;));
log.info(&quot;eWalletInfo: &quot; + vars.get(&quot;eWalletInfo&quot;));
log.info(&quot;wireTransferInfo: &quot; + vars.get(&quot;wireTransferInfo&quot;));
log.info(&quot;bankInfo: &quot; + vars.get(&quot;bankInfo&quot;));
log.info(&quot;===== 读取CSV参数结束 =====\n&quot;);

// ======================================
// 2. 读取参数并兜底
// ======================================
String token = vars.get(&quot;token&quot;);
if (token == null || token.trim().isEmpty()) {
    token = &quot;&quot;;
    log.warn(&quot;token为空，请检查上一个接口的token提取逻辑！&quot;);
}

String withdrawType = vars.get(&quot;withdraw_type&quot;);
if (withdrawType == null || withdrawType.trim().isEmpty()) {
    withdrawType = &quot;ewallet&quot;;
    log.info(&quot;withdraw_type为空，使用默认值: ewallet&quot;);
}

String accountId = vars.get(&quot;accountId&quot;);
if (accountId == null || accountId.trim().isEmpty()) accountId = &quot;40857&quot;;

String sourceType = vars.get(&quot;sourceType&quot;);
if (sourceType == null || sourceType.trim().isEmpty()) sourceType = &quot;1&quot;;

String amount = vars.get(&quot;amount&quot;);
if (amount == null || amount.trim().isEmpty()) amount = &quot;100&quot;;

String channelId = vars.get(&quot;channelId&quot;);
if (channelId == null || channelId.trim().isEmpty()) channelId = &quot;4&quot;;

String paymentMethod = vars.get(&quot;paymentMethod&quot;);
if (paymentMethod == null || paymentMethod.trim().isEmpty()) paymentMethod = &quot;4&quot;;

String currencyId = vars.get(&quot;currencyId&quot;);
if (currencyId == null || currencyId.trim().isEmpty()) currencyId = &quot;45&quot;;

String cardInfo = vars.get(&quot;cardInfo&quot;);
if (cardInfo == null) cardInfo = &quot;&quot;;

String cryptoInfo = vars.get(&quot;cryptoInfo&quot;);
if (cryptoInfo == null) cryptoInfo = &quot;&quot;;

String eWalletInfo = vars.get(&quot;eWalletInfo&quot;);
if (eWalletInfo == null) eWalletInfo = &quot;&quot;;

String wireTransferInfo = vars.get(&quot;wireTransferInfo&quot;);
if (wireTransferInfo == null) wireTransferInfo = &quot;&quot;;

String bankInfo = vars.get(&quot;bankInfo&quot;);
if (bankInfo == null) bankInfo = &quot;&quot;;

// ======================================
// 3. 拼接基础JSON
// ======================================
String baseJson = &quot;{&quot;
    + &quot;\&quot;token\&quot;:\&quot;&quot; + token + &quot;\&quot;,&quot;
    + &quot;\&quot;accountId\&quot;:&quot; + accountId + &quot;,&quot;
    + &quot;\&quot;sourceType\&quot;:&quot; + sourceType + &quot;,&quot;
    + &quot;\&quot;amount\&quot;:&quot; + amount + &quot;,&quot;
    + &quot;\&quot;channelId\&quot;:&quot; + channelId + &quot;,&quot;
    + &quot;\&quot;paymentMethod\&quot;:&quot; + paymentMethod + &quot;,&quot;
    + &quot;\&quot;currencyId\&quot;:&quot; + currencyId;

// ======================================
// 4. 动态拼接对应info字段
// ======================================
String finalJson = &quot;&quot;;
if (withdrawType.equals(&quot;card&quot;)) {
    finalJson = baseJson + (cardInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;cardInfo\&quot;:&quot; + cardInfo + &quot;}&quot;);
} else if (withdrawType.equals(&quot;crypto&quot;)) {
    finalJson = baseJson + (cryptoInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;cryptoInfo\&quot;:&quot; + cryptoInfo + &quot;}&quot;);
} else if (withdrawType.equals(&quot;ewallet&quot;)) {
    finalJson = baseJson + (eWalletInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;eWalletInfo\&quot;:&quot; + eWalletInfo + &quot;}&quot;);
} else if (withdrawType.equals(&quot;wiretransfer&quot;)) {
    finalJson = baseJson + (wireTransferInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;wireTransferInfo\&quot;:&quot; + wireTransferInfo + &quot;}&quot;);
} else if (withdrawType.equals(&quot;banktransfer&quot;)) {
    finalJson = baseJson + (bankInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;bankInfo\&quot;:&quot; + bankInfo + &quot;}&quot;);
} else {
    log.error(&quot;未知出金类型：&quot; + withdrawType + &quot;，使用ewallet兜底&quot;);
    finalJson = baseJson + (eWalletInfo.isEmpty() ? &quot;}&quot; : &quot;,\&quot;eWalletInfo\&quot;:&quot; + eWalletInfo + &quot;}&quot;);
}

// ======================================
// 5. 存入变量
// ======================================
vars.put(&quot;request_body&quot;, finalJson);
log.info(&quot;最终组装的请求体：\n&quot; + finalJson);</stringProp>
              <stringProp name="TestPlan.comments">拼接请求</stringProp>
            </BeanShellPreProcessor>
